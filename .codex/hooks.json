{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/agentic/prompt_memory_reminder.py",
            "statusMessage": "Loading memory reminder",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/agentic/pre_bash_safety_guard.py",
            "statusMessage": "Checking Bash command",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write|^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/agentic/pre_write_secret_scan.py",
            "statusMessage": "Scanning for secret-shaped strings",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/agentic/post_edit_code_quality.py",
            "statusMessage": "Reviewing changed files",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ./scripts/agentic/post_task_docs_sync.py",
            "statusMessage": "Checking documentation sync",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "python3 ./scripts/agentic/session_end_orphan_check.py",
            "statusMessage": "Checking lingering processes",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
